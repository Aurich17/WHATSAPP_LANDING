---
---
<section class="py-16 md:py-24 relative overflow-hidden" id="demo">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left Content -->
      <div class="order-2 md:order-1">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-xs font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Demo en Tiempo Real
        </div>
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
          Así funciona tu <span class="text-green-500">Asistente Virtual</span>
        </h2>
        <p class="text-gray-400 text-lg mb-8">
          Tus clientes reciben atención inmediata. El bot los guía, resuelve dudas y cierra ventas por ti.
        </p>
        
        <ul class="space-y-4 mb-8">
          <li class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center text-green-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="text-gray-300">Responde en menos de 3 segundos</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center text-green-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="text-gray-300">Menús interactivos fáciles de usar</span>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center text-green-500">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span class="text-gray-300">Disponible 24/7 sin descanso</span>
          </li>
        </ul>

        <a href="https://wa.me/51941300176" class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-black font-bold py-4 px-8 rounded-xl transition-all hover:scale-105 shadow-[0_0_20px_rgba(34,197,94,0.3)]">
          Probar Demo en Vivo
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Right Content (Phone Simulation) -->
      <div class="order-1 md:order-2 flex justify-center perspective-1000">
        <div class="relative w-[300px] h-[600px] bg-black border-[12px] border-[#1f2937] rounded-[3rem] shadow-2xl overflow-hidden transform rotate-y-12 hover:rotate-y-0 transition-transform duration-500">
          <!-- Notch -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-[#1f2937] rounded-b-xl z-20"></div>
          
          <!-- Screen -->
          <div class="w-full h-full bg-[#0b141a] flex flex-col relative">
            <!-- Header -->
            <div class="bg-[#202c33] p-4 pt-12 flex items-center gap-3 border-b border-gray-800 z-10 shadow-sm">
              <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-white font-bold text-xs">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <div class="text-white text-sm font-bold">Bot de Ventas</div>
                <div class="text-green-500 text-[10px] uppercase tracking-wide">En línea</div>
              </div>
              <div class="ml-auto flex gap-3 text-green-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
            </div>

            <!-- Chat Area -->
            <div class="flex-1 p-4 overflow-hidden relative space-y-4 font-sans text-sm bg-[url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png')] bg-repeat bg-opacity-10">
              
              <!-- Message 1 (User) -->
              <div class="flex justify-end animate-slide-in-right" style="animation-delay: 0.5s;">
                <div class="bg-[#005c4b] text-white p-2.5 px-3 rounded-lg rounded-tr-none max-w-[80%] shadow-sm text-sm">
                  Hola, precio
                  <div class="text-[10px] text-gray-300 text-right mt-0.5 flex justify-end items-center gap-1">
                    10:45 <span class="text-blue-400">✓✓</span>
                  </div>
                </div>
              </div>

              <!-- Message 2 (Bot) -->
              <div class="flex justify-start animate-slide-in-left" style="animation-delay: 1.2s;">
                <div class="bg-[#202c33] text-white p-3 rounded-lg rounded-tl-none max-w-[90%] shadow-sm text-sm border border-gray-800">
                  👋 ¡Hola! Soy el asistente virtual.
                  <br><br>
                  Selecciona una opción:
                  <div class="mt-2 space-y-1.5">
                    <button class="w-full text-left bg-[#2a3942] hover:bg-[#374248] p-2 rounded text-[#00a884] text-xs font-medium transition-colors border border-gray-700">1. Ver Planes 🚀</button>
                    <button class="w-full text-left bg-[#2a3942] hover:bg-[#374248] p-2 rounded text-[#00a884] text-xs font-medium transition-colors border border-gray-700">2. Asesor Humano 👨‍💻</button>
                  </div>
                  <div class="text-[10px] text-gray-400 text-right mt-1">10:45</div>
                </div>
              </div>

              <!-- Message 3 (User) -->
              <div class="flex justify-end animate-slide-in-right" style="animation-delay: 3s;">
                <div class="bg-[#005c4b] text-white p-2.5 px-3 rounded-lg rounded-tr-none max-w-[80%] shadow-sm text-sm">
                  1
                  <div class="text-[10px] text-gray-300 text-right mt-0.5 flex justify-end items-center gap-1">
                    10:46 <span class="text-blue-400">✓✓</span>
                  </div>
                </div>
              </div>

              <!-- Message 4 (Bot) -->
              <div class="flex justify-start animate-slide-in-left" style="animation-delay: 3.8s;">
                <div class="bg-[#202c33] text-white p-3 rounded-lg rounded-tl-none max-w-[90%] shadow-sm text-sm border border-gray-800">
                  <b>Plan Básico:</b> $50 (Único)
                  <br>
                  <b>Plan Pro:</b> $90 (Mensual)
                  <br><br>
                  ¿Deseas una demo?
                  <div class="mt-2 flex gap-2">
                     <button class="flex-1 bg-[#2a3942] p-1.5 rounded text-[#00a884] text-xs font-medium text-center">Sí</button>
                     <button class="flex-1 bg-[#2a3942] p-1.5 rounded text-[#00a884] text-xs font-medium text-center">No</button>
                  </div>
                  <div class="text-[10px] text-gray-400 text-right mt-1">10:46</div>
                </div>
              </div>
            </div>

            <!-- Input Area -->
            <div class="bg-[#202c33] p-2 px-3 flex items-center gap-2 border-t border-gray-800">
              <div class="w-8 h-8 rounded-full bg-[#2a3942] flex items-center justify-center text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>
              </div>
              <div class="flex-1 bg-[#2a3942] h-9 rounded-full px-4 text-sm flex items-center text-gray-400">
                Mensaje
              </div>
              <div class="w-9 h-9 rounded-full bg-[#00a884] flex items-center justify-center text-white">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes slideInRight {
    from { opacity: 0; transform: translateX(10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .animate-slide-in-left {
    opacity: 0;
    animation: slideInLeft 0.5s ease-out forwards;
  }

  .animate-slide-in-right {
    opacity: 0;
    animation: slideInRight 0.5s ease-out forwards;
  }

  .perspective-1000 {
    perspective: 1000px;
  }
</style>