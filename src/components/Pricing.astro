---
---
<section class="py-24 relative overflow-hidden">
  <!-- Reduced glow opacity and size to prevent washing out text -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-green-500/5 rounded-full blur-[120px] -z-10"></div>
  
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-3xl md:text-5xl font-bold mb-6">
      Plan simple y accesible
    </h2>
    <p class="text-gray-400 text-lg mb-12">
      Sin comisiones ocultas. Todo lo que necesitas para empezar.
    </p>

    <div class="relative inline-block w-full max-w-md">
      <!-- Gradient border effect - kept but adjusted -->
      <div class="absolute -inset-[1px] rounded-3xl bg-gradient-to-b from-green-500/50 to-green-900/50 opacity-100 blur-[1px]"></div>
      
      <!-- Card background made darker for better contrast -->
      <div class="relative bg-[#0F1110] border border-green-500/20 p-10 rounded-3xl text-left h-full shadow-2xl shadow-green-900/20">
        <div class="absolute top-0 right-0 bg-green-500/10 text-green-400 border-l border-b border-green-500/20 font-bold text-xs px-4 py-2 rounded-bl-xl rounded-tr-3xl uppercase tracking-wider">
          Más popular
        </div>

        <h3 class="text-2xl font-semibold mb-2 text-white">Plan Básico</h3>
        <p class="text-gray-400 text-sm mb-6">Ideal para pequeños negocios</p>

        <div class="flex items-end gap-2 mb-2">
          <span class="text-5xl font-bold text-white tracking-tight">$50</span>
          <span class="text-gray-400 mb-2 font-medium">/ único</span>
        </div>
        <p class="text-sm text-gray-500 mb-6">Costo de configuración e implementación</p>

        <div class="flex items-end gap-2 mb-8 pb-8 border-b border-gray-800">
          <span class="text-4xl font-bold text-white tracking-tight">$25</span>
          <span class="text-gray-400 mb-2 font-medium">/ mes</span>
          <p class="text-sm text-gray-500 mb-2 ml-auto">Mantenimiento</p>
        </div>

        <ul class="space-y-4 mb-8">
          <li class="flex items-center gap-3 text-gray-300">
            <div class="bg-green-500/10 p-1.5 rounded-full text-green-400 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Menú automático personalizado</span>
          </li>
          <li class="flex items-center gap-3 text-gray-300">
            <div class="bg-green-500/10 p-1.5 rounded-full text-green-400 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Respuestas 24/7 sin interrupciones</span>
          </li>
          <li class="flex items-center gap-3 text-gray-300">
            <div class="bg-green-500/10 p-1.5 rounded-full text-green-400 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Derivación inteligente a humano</span>
          </li>
          <li class="flex items-center gap-3 text-gray-300">
            <div class="bg-green-500/10 p-1.5 rounded-full text-green-400 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Soporte técnico prioritario</span>
          </li>
        </ul>

        <a
          href="https://wa.me/51938791015"
          class="block w-full text-center bg-green-500 hover:bg-green-400 text-black font-bold px-8 py-4 rounded-xl transition-all duration-300 hover:shadow-[0_0_20px_rgba(34,197,94,0.3)] transform hover:-translate-y-1"
        >
          Quiero este plan
        </a>
        
        <p class="text-center text-xs text-gray-500 mt-4">
          Garantía de satisfacción o te devolvemos tu dinero.
        </p>
      </div>
    </div>
  </div>
</section>
