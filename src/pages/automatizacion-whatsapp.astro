---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import Pricing from "../components/Pricing.astro";
import CTA from "../components/CTA.astro";
import FAQ from "../components/FAQ.astro";
import Testimonials from "../components/Testimonials.astro";
import HowItWorks from "../components/HowItWorks.astro";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- SEO General -->
    <title>Automatización de WhatsApp para Negocios y Empresas</title>
    <meta name="description" content="Descubre cómo la automatización de WhatsApp con bots y mensajes automáticos puede transformar tu negocio. Atención 24/7 y más ventas." />
    <meta name="keywords" content="automatizacion whatsapp, bots whatsapp, mensajes automaticos whatsapp business, whatsapp api empresas, chatbot whatsapp" />
    <meta name="author" content="WhatsApp Automation" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://whatsappautomation.online/automatizacion-whatsapp/" />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content="https://whatsappautomation.online/automatizacion-whatsapp/" />
    <meta property="og:title" content="Automatización de WhatsApp para Negocios y Empresas" />
    <meta property="og:description" content="Guía completa sobre automatización de WhatsApp: bots, respuestas automáticas y API para empresas." />
    <meta property="og:locale" content="es_ES" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#0a0a0a] text-white font-sans antialiased overflow-x-hidden relative selection:bg-green-500/30 selection:text-green-200">
    <Navbar />
    <div class="fixed inset-0 z-[-1] h-full w-full bg-[#0a0a0a] bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(34,197,94,0.15),rgba(255,255,255,0))]"></div>

    <!-- H1 Hero Section -->
    <section class="min-h-[70vh] flex items-center justify-center text-center px-6 relative overflow-hidden pt-20">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-green-500/20 rounded-full blur-[80px] md:blur-[100px] -z-10"></div>
      
      <div class="max-w-4xl z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-green-500/30 bg-green-500/10 text-green-400 text-sm font-medium mb-8">
          Tecnología para Empresas
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold mb-8 tracking-tight leading-tight">
          Automatización de WhatsApp: <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-600">Bots y Mensajes Automáticos</span>
        </h1>

        <p class="text-gray-400 text-base md:text-xl mb-6 max-w-2xl mx-auto leading-relaxed">
          ¿Tu equipo no puede responder a todos? La guía definitiva para escalar la atención al cliente de tu negocio utilizando la API oficial de WhatsApp Business.
        </p>

        <p class="text-green-400 font-semibold text-lg mb-10">
          Planes desde <span class="text-white text-2xl font-bold">$49/mes</span>
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full sm:w-auto">
          <a
            href="https://wa.me/51941300176?text=Hola,%20me%20interesa%20la%20automatización%20de%20WhatsApp"
            class="group relative inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-400 text-black font-bold px-6 py-3 md:px-8 md:py-4 rounded-xl transition-all duration-300 hover:shadow-[0_0_20px_rgba(34,197,94,0.4)] hover:-translate-y-1 w-full sm:w-auto text-lg"
          >
            Hablar con un experto
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Contenido Educativo -->
    <div class="max-w-4xl mx-auto px-6 py-16 space-y-24">
      
      <!-- Introducción -->
      <section>
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">¿Por qué automatizar tu WhatsApp?</h2>
        <div class="prose prose-invert prose-lg text-gray-400">
          <p>
            En la era digital actual, los clientes esperan respuestas inmediatas. La automatización de WhatsApp permite a las empresas gestionar miles de conversaciones simultáneamente sin perder calidad en la atención.
          </p>
          <p class="mt-4">
            Utilizando herramientas como <a href="/bot-whatsapp-empresas/" class="text-green-400 hover:underline">bots de WhatsApp para empresas</a>, puedes filtrar consultas, calificar leads y resolver dudas frecuentes automáticamente.
          </p>
          
          <div class="bg-green-900/20 border-l-4 border-green-500 p-6 mt-8 rounded-r-xl">
            <p class="text-white italic">
              "Si buscas <strong>automatización de WhatsApp en Perú</strong>, conoce nuestro <a href="/whatsapp-business-automatizado-peru/" class="text-green-400 font-bold hover:underline">servicio especializado para el mercado peruano</a>."
            </p>
          </div>
        </div>
      </section>

      <!-- Tipos de Automatización -->
      <section>
        <h2 class="text-3xl md:text-4xl font-bold mb-10 text-white">Tipos de mensajes automáticos</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white/5 p-6 rounded-2xl border border-white/10">
            <h3 class="text-xl font-semibold text-white mb-3">Mensajes de Bienvenida</h3>
            <p class="text-gray-400 text-sm">El primer contacto es crucial. Saluda a tus clientes al instante y ofrece un menú de opciones claro.</p>
          </div>
          <div class="bg-white/5 p-6 rounded-2xl border border-white/10">
            <h3 class="text-xl font-semibold text-white mb-3">Respuestas Rápidas</h3>
            <p class="text-gray-400 text-sm">Configura respuestas predefinidas para preguntas comunes como horarios, precios o ubicación.</p>
          </div>
          <div class="bg-white/5 p-6 rounded-2xl border border-white/10">
            <h3 class="text-xl font-semibold text-white mb-3">Flujos Conversacionales</h3>
            <p class="text-gray-400 text-sm">Guía al usuario paso a paso hasta la compra o la reserva sin intervención humana.</p>
          </div>
        </div>
        <p class="mt-6 text-center text-gray-400">
          Aprende más sobre <a href="/respuestas-automaticas-whatsapp-business/" class="text-green-400 hover:underline">respuestas automáticas en WhatsApp Business</a>.
        </p>
      </section>

      <!-- Beneficios Generales -->
      <section>
        <h2 class="text-3xl md:text-4xl font-bold mb-10 text-white">Ventajas para tu empresa</h2>
        <ul class="space-y-4 text-gray-300">
          <li class="flex items-start gap-3">
            <div class="bg-green-500/20 p-1 rounded-full text-green-400 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span><strong>Escalabilidad:</strong> Atiende a 10 o a 10,000 clientes con la misma eficiencia.</span>
          </li>
          <li class="flex items-start gap-3">
            <div class="bg-green-500/20 p-1 rounded-full text-green-400 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span><strong>Disponibilidad:</strong> Tu negocio nunca cierra gracias a la atención 24/7.</span>
          </li>
          <li class="flex items-start gap-3">
            <div class="bg-green-500/20 p-1 rounded-full text-green-400 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span><strong>Mejor experiencia:</strong> Reduce la fricción y aumenta la satisfacción del cliente.</span>
          </li>
        </ul>
        <div class="mt-8 text-center">
             <a href="/whatsapp-para-atencion-al-cliente/" class="inline-block text-white border-b border-green-500 pb-1 hover:text-green-400 transition-colors">Ver cómo mejora la atención al cliente &rarr;</a>
        </div>
      </section>

    </div>

    <!-- Componentes de cierre -->
    <HowItWorks />
    <Pricing />
    <FAQ />
    <CTA />
    <Footer />
    <FloatingWhatsApp />
  </body>
</html>