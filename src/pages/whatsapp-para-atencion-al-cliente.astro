---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import Pricing from "../components/Pricing.astro";
import CTA from "../components/CTA.astro";
import FAQ from "../components/FAQ.astro";
import Testimonials from "../components/Testimonials.astro";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- SEO Específico -->
    <title>WhatsApp para Atención al Cliente | Soporte 24/7</title>
    <meta name="description" content="Mejora tu servicio al cliente usando WhatsApp. Reduce tiempos de espera, aumenta la satisfacción y fideliza clientes con atención instantánea." />
    <meta name="keywords" content="whatsapp atencion al cliente, soporte whatsapp, servicio al cliente whatsapp, customer service whatsapp" />
    <meta name="author" content="WhatsApp Automation" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://whatsappautomation.online/whatsapp-para-atencion-al-cliente/" />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content="https://whatsappautomation.online/whatsapp-para-atencion-al-cliente/" />
    <meta property="og:title" content="WhatsApp para Atención al Cliente | Soporte 24/7" />
    <meta property="og:description" content="Transforma tu atención al cliente con WhatsApp Business." />
    <meta property="og:locale" content="es_ES" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#0a0a0a] text-white font-sans antialiased overflow-x-hidden relative selection:bg-green-500/30 selection:text-green-200">
    <Navbar />
    <div class="fixed inset-0 z-[-1] h-full w-full bg-[#0a0a0a] bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(34,197,94,0.15),rgba(255,255,255,0))]"></div>

    <!-- H1 Hero Section -->
    <section class="min-h-[60vh] flex items-center justify-center text-center px-6 relative overflow-hidden pt-20">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[500px] md:h-[500px] bg-green-500/20 rounded-full blur-[80px] md:blur-[100px] -z-10"></div>
      
      <div class="max-w-4xl z-10">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-8 tracking-tight leading-tight">
          WhatsApp para <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-600">Atención al Cliente</span>
        </h1>

        <p class="text-gray-400 text-base md:text-xl mb-6 max-w-2xl mx-auto leading-relaxed">
          ¿Soporte saturado? La herramienta preferida por los clientes. Ofrece soporte rápido, personal y eficiente.
        </p>

        <p class="text-green-400 font-semibold text-lg mb-10">
          Planes desde <span class="text-white text-2xl font-bold">$49/mes</span>
        </p>
      </div>
    </section>

    <!-- Contenido Educativo -->
    <div class="max-w-3xl mx-auto px-6 py-16 space-y-16">
      
      <!-- Importancia -->
      <section>
        <h2 class="text-2xl md:text-3xl font-bold mb-6 text-white">¿Por qué usar WhatsApp para soporte?</h2>
        <div class="prose prose-invert prose-lg text-gray-400">
          <p>
            El correo electrónico es lento y las llamadas telefónicas son intrusivas. WhatsApp ofrece el equilibrio perfecto: es asíncrono pero inmediato.
          </p>
          <ul class="list-disc pl-5 mt-4 space-y-2">
            <li>Tasa de apertura del 98%.</li>
            <li>Canal que el cliente ya usa y confía.</li>
            <li>Posibilidad de enviar fotos, videos y documentos fácilmente.</li>
          </ul>
        </div>
      </section>

      <!-- Mejores Prácticas -->
      <section>
        <h2 class="text-2xl md:text-3xl font-bold mb-6 text-white">Claves del éxito</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white/5 p-6 rounded-xl">
            <h3 class="font-bold text-green-400 mb-2">Velocidad</h3>
            <p class="text-gray-400 text-sm">Utiliza <a href="/respuestas-automaticas-whatsapp-business/" class="text-white hover:underline">respuestas automáticas</a> para el primer contacto.</p>
          </div>
          <div class="bg-white/5 p-6 rounded-xl">
            <h3 class="font-bold text-green-400 mb-2">Escalabilidad</h3>
            <p class="text-gray-400 text-sm">Implementa un <a href="/bot-whatsapp-empresas/" class="text-white hover:underline">bot para empresas</a> que maneje el volumen alto.</p>
          </div>
        </div>
      </section>

      <!-- CTA Final -->
      <div class="bg-gradient-to-r from-green-900/40 to-black p-8 rounded-2xl border border-green-500/20 text-center">
        <h3 class="text-xl font-bold text-white mb-4">Mejora tu atención al cliente hoy</h3>
        <p class="text-gray-400 mb-6">
          Si tu negocio está en Perú, podemos ayudarte a implementar el mejor sistema de soporte.
        </p>
        <a href="/whatsapp-business-automatizado-peru/" class="inline-block bg-white text-black font-bold px-8 py-3 rounded-full hover:bg-gray-200 transition-colors">
          Consultar planes en Perú
        </a>
      </div>

    </div>

    <Testimonials />
    <FAQ />
    <Footer />
    <FloatingWhatsApp />
  </body>
</html>