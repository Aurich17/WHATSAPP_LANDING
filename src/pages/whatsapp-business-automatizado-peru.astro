---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import Pricing from "../components/Pricing.astro";
import CTA from "../components/CTA.astro";
import FAQ from "../components/FAQ.astro";
import Testimonials from "../components/Testimonials.astro";
import HowItWorks from "../components/HowItWorks.astro";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- SEO Específico -->
    <title>Automatización de WhatsApp Business en Perú | Mensajes automáticos 24/7</title>
    <meta name="description" content="Automatiza tu WhatsApp Business en Perú. Respuestas automáticas, confirmaciones y atención 24/7 desde $49 al mes. Aumenta tus ventas hoy." />
    <meta name="keywords" content="whatsapp business automatizado peru, automatizacion whatsapp peru, bot whatsapp peru, empresas peru, negocios peruanos, soporte en peru" />
    <meta name="author" content="WhatsApp Automation Perú" />
    <meta name="geo.region" content="PE" />
    <meta name="geo.placename" content="Peru" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://whatsappautomation.online/whatsapp-business-automatizado-peru/" />

