---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import Solution from "../components/Solution.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Pricing from "../components/Pricing.astro";
import Testimonials from "../components/Testimonials.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import ProductDemo from "../components/ProductDemo.astro";
// import TechStack from "../components/TechStack.astro";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    
    <!-- SEO Principal -->
    <title>Automatización de WhatsApp Business | Respuestas automáticas 24/7</title>
    <meta name="description" content="¿Pierdes clientes por no responder? Automatiza tu WhatsApp Business hoy. Nuestro Bot atiende, vende y agenda por ti las 24 horas. ¡Servicio para Perú y Latinoamérica!" />
    <meta name="keywords" content="chatbot whatsapp peru, automatizacion whatsapp, bot ventas whatsapp, whatsapp business api peru, respuestas automaticas, robot whatsapp, chatbot whatsapp latinoamerica" />
    <meta name="author" content="WhatsApp Automation" />
    <meta name="geo.region" content="PE" />
    <meta name="geo.placename" content="Peru" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://whatsappautomation.online/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://whatsappautomation.online/" />
    <meta property="og:title" content="Automatización de WhatsApp 24/7 | No pierdas más clientes" />
    <meta property="og:description" content="Responde automáticamente a tus clientes 24/7 aunque estés ocupado. Recupera tu tiempo y aumenta tus ventas con nuestro bot para WhatsApp." />
    <meta property="og:image" content="https://whatsappautomation.online/og-image.jpg" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://whatsappautomation.online/" />
    <meta property="twitter:title" content="Automatización de WhatsApp 24/7 | No pierdas más clientes" />
    <meta property="twitter:description" content="Responde automáticamente a tus clientes 24/7 aunque estés ocupado. Recupera tu tiempo y aumenta tus ventas con nuestro bot para WhatsApp." />
    <meta property="twitter:image" content="https://whatsappautomation.online/og-image.jpg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "WhatsApp Automation",
        "image": "https://whatsappautomation.online/logo.png",
        "description": "Servicio de automatización de respuestas y chatbots para WhatsApp Business.",
        "url": "https://whatsappautomation.online/",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "PE"
        },
        "offers": {
          "@type": "Offer",
          "price": "50",
          "priceCurrency": "USD",
          "name": "Plan Básico de Automatización"
        }
      }
    </script>
  </head>
  <body class="bg-[#0a0a0a] text-white font-sans antialiased overflow-x-hidden relative selection:bg-green-500/30 selection:text-green-200">
    <Navbar />
    <div class="fixed inset-0 z-[-1] h-full w-full bg-[#0a0a0a] bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(34,197,94,0.15),rgba(255,255,255,0))]"></div>
    <Hero />
    <!-- <TechStack /> -->
    <Problem />
    <Solution />
    <ProductDemo />
    <HowItWorks />
    <Pricing />
    <Testimonials />
    <FAQ />
    <CTA />
    <Footer />
    <FloatingWhatsApp />
  </body>
</html>
